generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Int      // price in HUF (fillér-free)
  category    String   // "pillow" | "poster"
  series      String   // "origin" | "nova"
  variant     String   // "core" | "linea" | "atelier"
  imageUrl    String
  images      String[] @default([])
  badge       String?  // "Core Series" | "Limited Edition" | null
  active      Boolean  @default(true)
  onSale      Boolean  @default(false)
  salePrice   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id              String   @id @default(cuid())
  status          String   @default("pending") // pending | paid | processing | shipped | delivered | cancelled
  email           String
  phone           String?
  shippingName    String
  shippingZip     String
  shippingCity    String
  shippingAddress String
  shippingNote    String?
  subtotal        Int
  shippingCost    Int      @default(0)
  total           Int
  stripePaymentId String?
  trackingNumber  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  price     Int
  // Personalization: birth data for pillow/poster
  babyName      String?
  birthDate     String?
  birthWeight   String?
  birthHeight   String?
  birthTime     String?
  customNote    String?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  image           String?
  phone           String?
  shippingName    String?
  shippingZip     String?
  shippingCity    String?
  shippingAddress String?
  newsletter      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  code        String?  @unique
  discountPct Int?     // percentage discount
  discountAmt Int?     // fixed amount discount in HUF
  active      Boolean  @default(true)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}
